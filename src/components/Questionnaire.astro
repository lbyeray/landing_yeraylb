---
const provinces = [
  "Álava", "Albacete", "Alicante", "Almería", "Asturias", "Ávila", "Badajoz", "Barcelona", 
  "Burgos", "Cáceres", "Cádiz", "Cantabria", "Castellón", "Ciudad Real", "Córdoba", "Cuenca", 
  "Girona", "Granada", "Guadalajara", "Guipúzcoa", "Huelva", "Huesca", "Islas Baleares", "Jaén", 
  "La Rioja", "Las Palmas", "León", "Lérida", "Lugo", "Madrid", "Málaga", "Murcia", "Navarra", 
  "Orense", "Palencia", "Pontevedra", "Salamanca", "Santa Cruz de Tenerife", "Segovia", "Sevilla", 
  "Soria", "Tarragona", "Teruel", "Toledo", "Valencia", "Valladolid", "Vizcaya", "Zamora", "Zaragoza", 
  "Ceuta", "Melilla"
];
---

<section id="cuestionario" class="py-16 md:py-24 relative scroll-mt-20">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    
    <!-- Outer Card Container -->
    <div class="glass-panel p-6 sm:p-10 rounded-3xl border border-slate-800 shadow-2xl relative overflow-hidden backdrop-blur-xl">
      
      <!-- Top Section Header -->
      <div class="text-center mb-8">
        <span class="text-xs font-bold tracking-widest text-emerald-400 uppercase bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-full inline-block mb-3">
          EVALUACIÓN GRATUITA
        </span>
        <h2 class="font-display text-2xl sm:text-3xl font-extrabold text-white">
          Comprueba tu caso ahora.
        </h2>
      </div>

      <!-- Step Counter & Progress Bar -->
      <div class="mb-8">
        <div class="flex items-center justify-between text-xs font-semibold text-slate-400 mb-2">
          <span id="step-label">Paso 1 de 5</span>
          <span id="progress-percent" class="font-mono text-emerald-400">0%</span>
        </div>
        <div class="w-full h-2.5 bg-slate-900 rounded-full overflow-hidden border border-slate-800 p-0.5">
          <div 
            id="progress-bar" 
            class="h-full bg-gradient-to-r from-emerald-500 to-teal-400 rounded-full transition-all duration-500 ease-out shadow-sm shadow-emerald-500/50" 
            style="width: 0%"
          ></div>
        </div>
      </div>

      <!-- Step Content Wrapper -->
      <div id="quiz-container">

        <!-- STEP 1 -->
        <div class="step-card space-y-6" data-step="1">
          <h3 class="font-display text-lg sm:text-xl font-bold text-slate-100 leading-snug">
            ¿A cuánto asciende el total de tus deudas acumuladas? <span class="text-slate-400 text-sm font-normal block sm:inline">(Préstamos, tarjetas, microcréditos...)</span>
          </h3>
          <div class="space-y-3">
            <button type="button" data-field="deudas" data-value="Menos de 10.000€" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>Menos de 10.000€</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
            <button type="button" data-field="deudas" data-value="Entre 10.000€ y 35.000€" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>Entre 10.000€ y 35.000€</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
            <button type="button" data-field="deudas" data-value="Más de 35.000€" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>Más de 35.000€</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
          </div>
        </div>

        <!-- STEP 2 -->
        <div class="step-card hidden space-y-6" data-step="2">
          <h3 class="font-display text-lg sm:text-xl font-bold text-slate-100 leading-snug">
            ¿A cuántas entidades diferentes les debes dinero? <span class="text-slate-400 text-sm font-normal block sm:inline">(Bancos, financieras, tarjetas, Hacienda...)</span>
          </h3>
          <div class="space-y-3">
            <button type="button" data-field="entidades" data-value="A una sola entidad" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>A una sola entidad</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
            <button type="button" data-field="entidades" data-value="A dos o más entidades diferentes" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>A dos o más entidades diferentes</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
          </div>
          <button type="button" class="prev-btn text-xs font-semibold text-slate-400 hover:text-slate-200 flex items-center gap-1.5 pt-2 transition-colors">
            ← Volver
          </button>
        </div>

        <!-- STEP 3 -->
        <div class="step-card hidden space-y-6" data-step="3">
          <h3 class="font-display text-lg sm:text-xl font-bold text-slate-100 leading-snug">
            ¿Dispones de algún tipo de ingreso regular? <span class="text-slate-400 text-sm font-normal block sm:inline">(Nómina, autónomo, pensión, prestación...)</span>
          </h3>
          <div class="space-y-3">
            <button type="button" data-field="ingresos" data-value="Sí, dispongo de ingresos" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>Sí, dispongo de ingresos</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
            <button type="button" data-field="ingresos" data-value="No, actualmente no" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>No, actualmente no</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
          </div>
          <button type="button" class="prev-btn text-xs font-semibold text-slate-400 hover:text-slate-200 flex items-center gap-1.5 pt-2 transition-colors">
            ← Volver
          </button>
        </div>

        <!-- STEP 4 -->
        <div class="step-card hidden space-y-6" data-step="4">
          <h3 class="font-display text-lg sm:text-xl font-bold text-slate-100 leading-snug">
            ¿Sufres actualmente llamadas de acoso de cobradores o riesgo inminente de embargo?
          </h3>
          <div class="space-y-3">
            <button type="button" data-field="urgencia" data-value="Sí, situación urgente" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-amber-400"></span>
                Sí, situación urgente
              </span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
            <button type="button" data-field="urgencia" data-value="No de momento" class="option-btn w-full p-4 rounded-xl glass-card border border-slate-800 hover:border-emerald-500/50 text-left flex items-center justify-between text-slate-200 font-medium transition-all group hover:bg-slate-850">
              <span>No de momento</span>
              <div class="w-5 h-5 rounded-full border border-slate-700 group-hover:border-emerald-500 flex items-center justify-center transition-colors">
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>
            </button>
          </div>
          <button type="button" class="prev-btn text-xs font-semibold text-slate-400 hover:text-slate-200 flex items-center gap-1.5 pt-2 transition-colors">
            ← Volver
          </button>
        </div>

        <!-- STEP 5 (Lead Form) -->
        <div class="step-card hidden space-y-6" data-step="5">
          <div>
            <h3 class="text-xl sm:text-2xl font-bold text-slate-100 mb-1">
              Casi listo. ¿A quién llamamos?
            </h3>
            <p class="text-xs sm:text-sm text-slate-400">
              Tus datos quedan protegidos y sólo se ceden al despacho de abogados asignado a tu provincia.
            </p>
          </div>

          <form id="lead-form" class="space-y-4">
            <div>
              <label for="nombre" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5">
                Nombre Completo *
              </label>
              <input 
                type="text" 
                id="nombre" 
                name="nombre" 
                required 
                placeholder="Ej. María García López" 
                class="glass-input w-full px-4 py-3 rounded-xl text-slate-100 placeholder-slate-500 text-sm focus:outline-none transition-all"
              />
            </div>

            <div>
              <label for="telefono" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5">
                Teléfono Móvil *
              </label>
              <input 
                type="tel" 
                id="telefono" 
                name="telefono" 
                required 
                placeholder="600 000 000" 
                pattern="[0-9]{9}"
                class="glass-input w-full px-4 py-3 rounded-xl text-slate-100 placeholder-slate-500 text-sm focus:outline-none transition-all"
              />
            </div>

            <div>
              <label for="provincia" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider mb-1.5">
                Provincia de Residencia *
              </label>
              <select 
                id="provincia" 
                name="provincia" 
                required 
                class="glass-input w-full px-4 py-3 rounded-xl text-slate-100 text-sm focus:outline-none transition-all bg-slate-900"
              >
                <option value="" disabled selected>Selecciona tu provincia...</option>
                {provinces.map((prov) => (
                  <option value={prov}>{prov}</option>
                ))}
              </select>
            </div>

            <div class="pt-2">
              <label class="flex items-start gap-3 cursor-pointer group">
                <input 
                  type="checkbox" 
                  id="privacy" 
                  name="privacy" 
                  required 
                  class="mt-1 rounded border-slate-700 bg-slate-900 text-emerald-500 focus:ring-emerald-500 focus:ring-offset-slate-900"
                />
                <span class="text-xs text-slate-400 leading-normal">
                  Acepto la <a href="#" class="text-emerald-400 underline hover:text-emerald-300">Política de Privacidad</a> y el tratamiento de mis datos para la evaluación de mi caso.
                </span>
              </label>
            </div>

            <!-- Disclaimer box -->
            <div class="p-3.5 rounded-xl bg-slate-900/80 border border-slate-800/80 text-[11px] text-slate-400 leading-relaxed">
              <strong>Información básica sobre protección de datos:</strong> El responsable es Defensa del Deudor. La finalidad es analizar la viabilidad de su caso. Le informamos de que para ofrecerle el servicio de asesoramiento solicitado, sus datos de contacto serán cedidos exclusivamente a nuestros despachos de abogados partners autorizados en su provincia, quienes le contactarán de forma totalmente gratuita.
            </div>

            <button 
              type="submit" 
              id="submit-btn" 
              class="w-full py-4 px-6 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold text-base flex items-center justify-center gap-2 shadow-lg shadow-emerald-500/20 transition-all active:scale-[0.99] disabled:opacity-50"
            >
              <span>Solicitar evaluación gratuita</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 stroke-[2.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </button>

            <div id="form-error" class="hidden text-xs text-rose-400 text-center font-medium pt-1"></div>
          </form>

          <button type="button" class="prev-btn text-xs font-semibold text-slate-400 hover:text-slate-200 flex items-center gap-1.5 pt-1 transition-colors">
            ← Volver
          </button>
        </div>

      </div> <!-- End quiz-container -->

      <!-- Success View (Hidden by default) -->
      <div id="success-view" class="hidden text-center py-8 space-y-6">
        <div class="w-16 h-16 bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded-full flex items-center justify-center mx-auto shadow-xl shadow-emerald-500/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 stroke-[2.5]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-2">¡Solicitud Enviada con Éxito!</h3>
          <p class="text-sm text-slate-300 max-w-md mx-auto leading-relaxed">
            Hemos registrado tus respuestas correctamente. Un abogado especializado de tu provincia se pondrá en contacto contigo por teléfono en menos de 24 horas.
          </p>
        </div>
        <div class="p-4 rounded-xl bg-slate-900 border border-slate-800 text-xs text-slate-400">
          Revisa tu teléfono móvil. Te llamaremos en horario laboral para tu asesoramiento gratuito.
        </div>
      </div>

    </div> <!-- End Card Container -->

    <!-- Trust badges below container -->
    <div class="flex items-center justify-center gap-4 text-xs font-medium text-slate-500 mt-6">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Datos cifrados
      </span>
      <span>•</span>
      <span>Confidencial</span>
      <span>•</span>
      <span>Sin compromiso</span>
    </div>

  </div>
</section>

<script>
  // Questionnaire logic & Google Sheets Integration
  document.addEventListener('DOMContentLoaded', () => {
    let currentStep = 1;
    const totalSteps = 5;
    
    // Form answers store
    const formData = {
      deudas: '',
      entidades: '',
      ingresos: '',
      urgencia: '',
      nombre: '',
      telefono: '',
      provincia: '',
      fecha: ''
    };

    const stepLabel = document.getElementById('step-label');
    const progressPercent = document.getElementById('progress-percent');
    const progressBar = document.getElementById('progress-bar');
    const stepCards = document.querySelectorAll('.step-card');
    const optionBtns = document.querySelectorAll('.option-btn');
    const prevBtns = document.querySelectorAll('.prev-btn');
    const leadForm = document.getElementById('lead-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('form-error');
    const quizContainer = document.getElementById('quiz-container');
    const successView = document.getElementById('success-view');

    function updateStepUI() {
      // Step percentage calculation
      const percentages = [0, 20, 40, 60, 80, 100];
      const pct = percentages[currentStep - 1];

      if (stepLabel) stepLabel.textContent = `Paso ${currentStep} de ${totalSteps}`;
      if (progressPercent) progressPercent.textContent = `${pct}%`;
      if (progressBar) progressBar.style.width = `${pct}%`;

      stepCards.forEach((card) => {
        const stepNum = parseInt(card.getAttribute('data-step') || '1');
        if (stepNum === currentStep) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }

    // Option selections
    optionBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const field = target.getAttribute('data-field');
        const value = target.getAttribute('data-value');

        if (field && value) {
          (formData as any)[field] = value;
        }

        if (currentStep < totalSteps) {
          currentStep++;
          updateStepUI();
        }
      });
    });

    // Previous step navigation
    prevBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (currentStep > 1) {
          currentStep--;
          updateStepUI();
        }
      });
    });

    // Form Submission & Webhook Handling
    if (leadForm) {
      const nombreInput = document.getElementById('nombre') as HTMLInputElement;
      const telefonoInput = document.getElementById('telefono') as HTMLInputElement;
      const provinciaSelect = document.getElementById('provincia') as HTMLSelectElement;
      const privacyCheck = document.getElementById('privacy') as HTMLInputElement;

      // Clean red border on input
      [nombreInput, telefonoInput, provinciaSelect, privacyCheck].forEach((el) => {
        if (!el) return;
        el.addEventListener('input', () => {
          el.classList.remove('border-rose-500', 'ring-1', 'ring-rose-500');
          if (formError) formError.classList.add('hidden');
        });
      });

      leadForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (formError) formError.classList.add('hidden');

        // Validation 1: Nombre (mínimo 3 caracteres)
        const nombreVal = nombreInput.value.trim();
        if (nombreVal.length < 3) {
          nombreInput.classList.add('border-rose-500', 'ring-1', 'ring-rose-500');
          if (formError) {
            formError.textContent = 'Por favor, introduce tu nombre completo válido (mínimo 3 caracteres).';
            formError.classList.remove('hidden');
          }
          nombreInput.focus();
          return;
        }

        // Validation 2: Teléfono móvil en España (9 dígitos, comenzando por 6, 7, 8 o 9)
        const rawPhone = telefonoInput.value.replace(/\s+/g, '').replace(/-/g, '').replace(/\+34/, '');
        const phoneRegex = /^[6789]\d{8}$/;
        if (!phoneRegex.test(rawPhone)) {
          telefonoInput.classList.add('border-rose-500', 'ring-1', 'ring-rose-500');
          if (formError) {
            formError.textContent = 'Por favor, escribe un número de teléfono móvil válido en España (9 dígitos).';
            formError.classList.remove('hidden');
          }
          telefonoInput.focus();
          return;
        }

        // Validation 3: Selección de Provincia
        if (!provinciaSelect.value) {
          provinciaSelect.classList.add('border-rose-500', 'ring-1', 'ring-rose-500');
          if (formError) {
            formError.textContent = 'Por favor, selecciona tu provincia de residencia.';
            formError.classList.remove('hidden');
          }
          provinciaSelect.focus();
          return;
        }

        // Validation 4: Checkbox de Privacidad
        if (!privacyCheck.checked) {
          privacyCheck.classList.add('ring-2', 'ring-rose-500');
          if (formError) {
            formError.textContent = 'Debes aceptar la política de privacidad para solicitar tu evaluación gratuita.';
            formError.classList.remove('hidden');
          }
          privacyCheck.focus();
          return;
        }

        formData.nombre = nombreVal;
        formData.telefono = rawPhone;
        formData.provincia = provinciaSelect.value;
        formData.fecha = new Date().toLocaleString('es-ES', { timeZone: 'Europe/Madrid' });

        // Disable button while submitting
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin h-5 w-5 text-slate-950 inline-block mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span>Procesando solicitud...</span>
        `;

        // Google Sheets Webhook Submission
        const webhookUrl = (import.meta as any).env?.PUBLIC_GOOGLE_SHEETS_WEBHOOK_URL;

        try {
          if (webhookUrl && webhookUrl.startsWith('http')) {
            await fetch(webhookUrl, {
              method: 'POST',
              mode: 'no-cors',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(formData),
            });
          } else {
            console.log('Lead data ready to submit to Google Sheets:', formData);
          }
        } catch (err) {
          console.warn('Network issue or webhook notice:', err);
        }

        // Show Success view
        if (quizContainer && successView) {
          quizContainer.classList.add('hidden');
          successView.classList.remove('hidden');
          if (stepLabel) stepLabel.textContent = `Paso 5 de 5`;
          if (progressPercent) progressPercent.textContent = `100%`;
          if (progressBar) progressBar.style.width = `100%`;
        }
      });
    }

    // Init UI
    updateStepUI();
  });
</script>
